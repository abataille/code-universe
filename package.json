{
  "name": "code-universe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "mcp": "node scripts/code-universe-mcp.js",
    "test:scan": "node scripts/test-scan-fixtures.js",
    "test:review": "node scripts/test-review-flow.js",
    "test:mcp": "node scripts/test-mcp.js",
    "scan:sample": "node scripts/scan-swift.js examples/SampleSwiftApp public/sample-graph.json",
    "scan:sample:swiftsyntax": "node scripts/scan-swift-syntax.js examples/SampleSwiftApp public/sample-graph.json",
    "review": "node scripts/code-universe-review.js",
    "mac:build": "swift build --package-path mac/CodeUniverseMac",
    "mac:run": "swift run --package-path mac/CodeUniverseMac CodeUniverseMac",
    "mac:bundle": "zsh scripts/build-mac-app-bundle.sh",
    "mac:open": "npm run mac:bundle && open \"dist/Code Universe.app\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "three": "^0.185.0",
    "zod": "^3.25.76"
  },
  "overrides": {
    "@hono/node-server": "2.0.11"
  }
}
